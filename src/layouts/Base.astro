---
import '@fontsource-variable/inter'
import '@fontsource/ibm-plex-mono/400.css'
import '@fontsource/ibm-plex-mono/500.css'
import '@fontsource/ibm-plex-mono/600.css'
import '../styles/global.css'
import { getSite } from '../config'
import { getCopy } from '../copy'
import { getLocaleFromPath, getLocalizedPath, LOCALES } from '../i18n'

interface Props {
  title?: string
  description?: string
}
const locale = getLocaleFromPath(Astro.url.pathname)
const siteMeta = getSite(locale)
const copy = getCopy(locale)
const { title = siteMeta.title, description = siteMeta.description } = Astro.props
const canonical = new URL(Astro.url.pathname, Astro.site)
const ogImage = new URL('/brand/og.png', Astro.site).href
const iconVersion = '2'
const alternates = [
  { href: new URL(getLocalizedPath('en', Astro.url.pathname), Astro.site).href, hreflang: LOCALES.en.lang },
  { href: new URL(getLocalizedPath('pt', Astro.url.pathname), Astro.site).href, hreflang: LOCALES.pt.lang },
]

/**
 * Cookieless analytics — off unless configured, so no tag ships by accident.
 *
 * Deliberately vendor-neutral: Plausible reads `data-domain`, Umami reads
 * `data-website-id`, and each ignores the other's attribute, so setting the
 * pair for one provider is enough. Both count without cookies and without
 * storing personal data on the device, which is why there is no consent
 * banner here — that is a property of the tool, so if you ever swap in one
 * that sets cookies, the banner question comes back with it.
 */
const analyticsSrc = import.meta.env.PUBLIC_ANALYTICS_SRC
const analyticsDomain = import.meta.env.PUBLIC_ANALYTICS_DOMAIN
const analyticsWebsiteId = import.meta.env.PUBLIC_ANALYTICS_WEBSITE_ID
---

<!doctype html>
<html lang={LOCALES[locale].lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />
    {alternates.map((alt) => <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />)}
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site).href} />
    <meta name="theme-color" content="#111111" />
    <meta name="color-scheme" content="light" />

    <link rel="icon" type="image/svg+xml" href={`/favicon.svg?v=${iconVersion}`} />
    <link rel="icon" type="image/png" href={`/brand/symbol.png?v=${iconVersion}`} sizes="64x64" />
    <link rel="apple-touch-icon" href={`/brand/apple-touch-icon.png?v=${iconVersion}`} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteMeta.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="generator" content={Astro.generator} />

    {
      analyticsSrc && (
        <script
          is:inline
          defer
          src={analyticsSrc}
          data-domain={analyticsDomain || undefined}
          data-website-id={analyticsWebsiteId || undefined}
        />
      )
    }
  </head>
  <body class="min-h-screen">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-foreground focus:px-4 focus:py-2 focus:text-sm focus:text-background"
    >
      {copy.a11y.skipToContent}
    </a>
    <slot />
  </body>
</html>
