---
/**
 * The page's structural spine — the section divider, drawn from the logo:
 * a hairline rule with a short red segment breaking through on the left
 * (the mark's red lower half) and the precision square riding the line on the
 * right. Aligned to the content grid.
 */
interface Props {
  class?: string
}
const { class: className = '' } = Astro.props
---

<div class={`wrap ${className}`} aria-hidden="true">
  <div class="relative h-px w-full bg-border">
    <span class="absolute left-0 top-0 h-px w-24 bg-primary"></span>
    <span class="absolute right-0 top-1/2 h-[9px] w-[9px] -translate-y-1/2 bg-foreground ring-[3px] ring-background"></span>
  </div>
</div>
