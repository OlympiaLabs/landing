---
/**
 * Evidence that the thing exists: the sensor on a real boat, a real session,
 * and the output a coach actually opens.
 *
 * Slots are driven by `PROOF_MEDIA` and ship empty. Only entries with a `src`
 * render, and the section removes itself entirely when none do — an empty grey
 * box would undercut the section's whole point. Drop a file in `public/proof/`,
 * set its `src` in config.ts, and it appears with its caption already written.
 */
import { PROOF_MEDIA } from '../config'
import { getCopy } from '../copy'
import { getLocaleFromPath } from '../i18n'

const locale = getLocaleFromPath(Astro.url.pathname)
const c = getCopy(locale).proof
const items = PROOF_MEDIA.filter((m) => m.src !== '').map((m) => ({ ...m, ...c.captions[m.key] }))
---

{
  items.length > 0 && (
    <section id="proof" class="scroll-mt-20">
      <div class="wrap py-24 md:py-32">
        <div class="max-w-2xl">
          <p class="label-caps">{c.eyebrow}</p>
          <h2 class="mt-5 text-[clamp(1.8rem,3.4vw,2.75rem)] font-semibold leading-[1.08] tracking-[-0.02em] text-foreground">
            {c.title}
          </h2>
          <p class="mt-6 text-lg leading-relaxed text-muted-foreground">{c.body}</p>
        </div>

        <div class="mt-14 grid grid-cols-1 gap-x-8 gap-y-12 sm:grid-cols-2">
          {items.map((m) => (
            <figure class:list={['reveal', m.span === 'full' && 'sm:col-span-2']}>
              <div class="aspect-video overflow-hidden border border-border bg-muted/40">
                {m.type === 'video' ? (
                  <video
                    src={m.src}
                    class="h-full w-full object-cover"
                    controls
                    muted
                    loop
                    playsinline
                    preload="metadata"
                    aria-label={m.alt}
                  />
                ) : (
                  <img src={m.src} alt={m.alt} class="h-full w-full object-cover" loading="lazy" decoding="async" />
                )}
              </div>
              <figcaption class="mt-3 flex gap-3 font-mono text-[0.66rem] uppercase tracking-label text-muted-foreground">
                <span aria-hidden="true" class="mt-1.5 h-px w-4 shrink-0 bg-primary" />
                <span>{m.caption}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )
}
