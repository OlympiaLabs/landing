---
/**
 * Section order carries the sales story: the promise, the coaching benefit,
 * the problem it solves, what it helps a coach notice, how it fits the weekly
 * workflow, the system behind it, and only then the ask.
 *
 * The light → muted → dark rhythm is structure, not theming. `Problem` and
 * `Pilot` are the two dark bands and set the page's cadence; check it still
 * alternates before reordering anything. `Proof` renders nothing until real
 * media is configured, and the rhythm holds either way.
 */
import Base from '../layouts/Base.astro'
import Nav from './Nav.astro'
import Hero from './Hero.astro'
import Waterline from './Waterline.astro'
import Stats from './Stats.astro'
import Proof from './Proof.astro'
import Problem from './Problem.astro'
import Loop from './Loop.astro'
import Observes from './Observes.astro'
import Coach from './Coach.astro'
import Pieces from './Pieces.astro'
import Pilot from './Pilot.astro'
import Footer from './Footer.astro'
---

<Base>
  <Nav />
  <main id="main">
    <Hero />
    <Waterline />
    <Stats />
    <Problem />
    <Coach />
    <Observes />
    <Proof />
    <Loop />
    <Pieces />
    <Pilot />
  </main>
  <Footer />
</Base>
