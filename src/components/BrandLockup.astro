---
import BrandMark from './BrandMark.astro'
import { getSite } from '../config'
import { getLocaleFromPath } from '../i18n'

/**
 * Mark + wordmark, aligned with the webapp lockup.
 */
interface Props {
  class?: string
  size?: 'sm' | 'md' | 'lg'
  tagline?: boolean
  href?: string | null
  ariaLabel?: string
}
const {
  class: className = '',
  size = 'md',
  tagline = false,
  href = null,
  ariaLabel = 'OlympiaLabs — home',
} = Astro.props

const markSize = { sm: 'size-5', md: 'size-6', lg: 'size-8' }[size]
const wordSize = { sm: 'text-sm', md: 'text-base', lg: 'text-xl' }[size]
const Tag = href ? 'a' : 'div'
const locale = getLocaleFromPath(Astro.url.pathname)
const siteMeta = getSite(locale)
---

<Tag
  class:list={['inline-flex items-center gap-2 transition-opacity hover:opacity-80', className]}
  {...href ? { href, 'aria-label': ariaLabel } : {}}
>
  <BrandMark class={`${markSize} shrink-0 text-primary`} />
  <span class="flex flex-col leading-none">
    <span class={`${wordSize} uppercase leading-none tracking-label text-foreground`}>
      <span class="font-bold">Olympia</span> <span class="font-normal">Labs</span>
    </span>
    {
      tagline && (
        <span class="mt-1.5 font-mono text-[0.55rem] font-medium uppercase tracking-wide2 text-primary">
          {siteMeta.tagline}
        </span>
      )
    }
  </span>
</Tag>
