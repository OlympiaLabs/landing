---
import BrandMark from './BrandMark.astro'

/**
 * Mark + wordmark. The wordmark reuses the LogoV1 split: "Olympia" bold,
 * "Labs" light — the one type gesture that recurs across the page.
 */
interface Props {
  class?: string
  size?: 'sm' | 'md' | 'lg'
  tagline?: boolean
  href?: string | null
  ariaLabel?: string
}
const {
  class: className = '',
  size = 'md',
  tagline = false,
  href = null,
  ariaLabel = 'OlympiaLabs — home',
} = Astro.props

const markSize = { sm: 'h-7', md: 'h-9', lg: 'h-12' }[size]
const wordSize = { sm: 'text-base', md: 'text-lg', lg: 'text-2xl' }[size]
const Tag = href ? 'a' : 'div'
---

<Tag
  class:list={['inline-flex items-center gap-3 transition-opacity hover:opacity-80', className]}
  {...href ? { href, 'aria-label': ariaLabel } : {}}
>
  <BrandMark class={`${markSize} w-auto shrink-0`} />
  <span class="flex flex-col leading-none">
    <span class={`${wordSize} leading-none tracking-tight text-foreground`}>
      <span class="font-bold">Olympia</span> <span class="font-light">Labs</span>
    </span>
    {
      tagline && (
        <span class="mt-1.5 font-mono text-[0.55rem] font-medium uppercase tracking-wide2 text-primary">
          Speed. Precision. Reliability.
        </span>
      )
    }
  </span>
</Tag>
