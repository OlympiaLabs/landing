<section id="technology" class="scroll-mt-20">
  <div class="wrap grid grid-cols-1 gap-12 py-24 md:py-32 lg:grid-cols-12 lg:gap-10">
    <div class="lg:col-span-5">
      <p class="label-caps">The system</p>
      <h2 class="mt-5 text-[clamp(1.8rem,3.4vw,2.75rem)] font-semibold leading-[1.08] tracking-[-0.02em] text-foreground">
        One system, built only for paddling.
      </h2>
      <p class="mt-6 max-w-md text-lg leading-relaxed text-muted-foreground">
        Most setups bolt together a watch, a phone and a coach's eye. OlympiaLabs is a
        single instrument — designed end to end for the kayak and the canoe.
      </p>
    </div>

    <div class="lg:col-span-7">
      <dl class="border-t border-border">
        {
          points.map((p) => (
            <div class="grid grid-cols-1 gap-2 border-b border-border py-7 sm:grid-cols-[10rem_1fr] sm:gap-8">
              <dt class="font-mono text-[0.66rem] font-medium uppercase tracking-label text-primary sm:pt-1">
                {p.tag}
              </dt>
              <dd>
                <p class="text-lg font-semibold tracking-tight text-foreground">{p.title}</p>
