---
import BrandLockup from './BrandLockup.astro'
import { NAV_LINKS, SIGN_IN_URL, getSite } from '../config'
import { getCopy } from '../copy'
import { getLocaleFromPath } from '../i18n'

const locale = getLocaleFromPath(Astro.url.pathname)
const copy = getCopy(locale)
const c = copy.footer
const siteMeta = getSite(locale)

// The Product column mirrors the nav rather than restating it — renaming a
// section used to mean editing this file and config.ts in step.
//
// A link whose page does not exist yet ships with an empty `href` and is
// filtered out below, along with any column that empties completely. Same
// contract as PROOF_MEDIA in config.ts: the slot stays written and waiting,
// and the page renders nothing rather than something hollow. It matters more
// than usual here — these were `href="#"`, and dead Privacy/Terms links sat
// directly under a form asserting "GDPR-compliant". Set the href when the page
// is real, and the column comes back on its own.
const columns = [
  {
    title: c.columns.product,
    links: [
      ...NAV_LINKS.map((l) => ({ href: l.href, label: copy.nav.links[l.key] })),
      { href: SIGN_IN_URL, label: copy.nav.signIn },
    ],
  },
  {
    title: c.columns.company,
    links: [
      { href: '', label: c.links.about },
      { href: `mailto:${siteMeta.contactEmail}`, label: c.links.contact },
    ],
  },
  {
    title: c.columns.legal,
    links: [
      { href: '', label: c.links.privacy },
      { href: '', label: c.links.terms },
    ],
  },
]
  .map((col) => ({ ...col, links: col.links.filter((l) => l.href !== '') }))
  .filter((col) => col.links.length > 0)

const year = new Date().getFullYear()
---

<footer class="border-t border-border">
  <div class="wrap py-16 md:py-20">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12">
      <div class="md:col-span-5">
        <BrandLockup size="md" tagline />
        <p class="mt-6 max-w-xs text-sm leading-relaxed text-muted-foreground">{c.blurb}</p>
      </div>

      <nav
        class:list={[
          'grid grid-cols-2 gap-8 md:col-span-7',
          columns.length >= 3 ? 'sm:grid-cols-3' : 'sm:grid-cols-2',
        ]}
        aria-label={copy.a11y.footerNav}
      >
        {
          columns.map((col) => (
            <div>
              <p class="label-caps">{col.title}</p>
              <ul class="mt-4 space-y-3 text-sm">
                {col.links.map((link) => (
                  <li>
                    <a class="text-muted-foreground transition-colors hover:text-foreground" href={link.href}>
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </nav>
    </div>

    <div
      class="mt-14 flex flex-col gap-3 border-t border-border pt-8 sm:flex-row sm:items-center sm:justify-between"
    >
      <p class="font-mono text-[0.7rem] uppercase tracking-label text-muted-foreground">© {year} {siteMeta.name}</p>
      <p class="font-mono text-[0.7rem] uppercase tracking-label text-muted-foreground">
        {c.madeIn} {siteMeta.location}
      </p>
    </div>
  </div>
</footer>
