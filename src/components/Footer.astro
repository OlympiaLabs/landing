---
import BrandLockup from './BrandLockup.astro'
import { SIGN_IN_URL, SITE } from '../config'

const columns = [
  {
    title: 'Product',
    links: [
      { href: '#measure', label: 'What we measure' },
      { href: '#system', label: 'System' },
      { href: '#technology', label: 'Technology' },
      { href: SIGN_IN_URL, label: 'Sign in' },
    ],
  },
  {
    title: 'Company',
    links: [
      { href: '#', label: 'About' },
      { href: 'mailto:hello@olympialabs.eu', label: 'Contact' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { href: '#', label: 'Privacy' },
      { href: '#', label: 'Terms' },
    ],
  },
]

const year = new Date().getFullYear()
---

<footer class="border-t border-border">
  <div class="wrap py-16 md:py-20">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12">
      <div class="md:col-span-5">
        <BrandLockup size="md" tagline />
        <p class="mt-6 max-w-xs text-sm leading-relaxed text-muted-foreground">
          Performance analytics for kayak racing. Measure the stroke — not just the effort.
        </p>
      </div>

      <nav class="grid grid-cols-2 gap-8 sm:grid-cols-3 md:col-span-7" aria-label="Footer">
        {
          columns.map((col) => (
            <div>
              <p class="label-caps">{col.title}</p>
              <ul class="mt-4 space-y-3 text-sm">
                {col.links.map((link) => (
                  <li>
                    <a class="text-muted-foreground transition-colors hover:text-foreground" href={link.href}>
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </nav>
    </div>

    <div class="mt-14 flex flex-col gap-3 border-t border-border pt-8 sm:flex-row sm:items-center sm:justify-between">
      <p class="font-mono text-[0.7rem] uppercase tracking-label text-muted-foreground">© {year} OlympiaLabs</p>
      <p class="font-mono text-[0.7rem] uppercase tracking-label text-muted-foreground">Made in {SITE.location}</p>
    </div>
  </div>
</footer>
