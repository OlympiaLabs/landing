---
/**
 * A stylised boat-motion trace for the hero.
 *
 * It stays illustrative on purpose; real traces and footage belong in the
 * proof section. This gives the page a technical anchor without pretending the
 * waveform itself is a live customer session.
 */
import { getCopy } from '../copy'
import { getLocaleFromPath } from '../i18n'

interface Props {
  class?: string
}
const { class: className = '' } = Astro.props
const locale = getLocaleFromPath(Astro.url.pathname)
const c = getCopy(locale).hero.signal

// Geometry of the plot area (SVG user units).
const W = 560
const H = 240
const baseline = 132
const amp = 58
const periods = 3.5
const periodPx = W / periods
const step = 3

// Build the trace as a dense polyline so we can (a) keep it smooth and
// (b) measure its exact length for a clean stroke-dash draw animation.
let d = ''
let len = 0
let px = 0
let py = 0
for (let x = 0; x <= W; x += step) {
  const i = Math.floor(x / periodPx)
  const a = amp * (i % 2 === 0 ? 1 : 0.88) // slight left/right amplitude difference
  const th = (2 * Math.PI * x) / periodPx
  const y = baseline - a * (Math.sin(th) + 0.32 * Math.sin(2 * th + 0.6))
  if (x === 0) {
    d = `M${x} ${y.toFixed(1)}`
  } else {
    d += ` L${x} ${y.toFixed(1)}`
    len += Math.hypot(x - px, y - py)
  }
  px = x
  py = y
}
const dashLen = Math.ceil(len) + 8
const markerX = 6 // square marker rides the axis at the first stroke
---

<figure class={`relative ${className}`} aria-label={c.aria}>
  <svg viewBox={`0 0 ${W} ${H}`} class="w-full overflow-visible" role="img" aria-hidden="true">
    <!-- waterline axis (ink) with a red segment, echoing the logo -->
    <line x1="0" y1={baseline} x2={W} y2={baseline} class="stroke-border" stroke-width="1" />
    <line x1="0" y1={baseline} x2={periodPx * 0.62} y2={baseline} class="stroke-primary" stroke-width="1.5" />

    <!-- the trace -->
    <path
      d={d}
      fill="none"
      class="signal-path stroke-foreground"
      stroke-width="2.25"
      stroke-linecap="round"
      stroke-linejoin="round"
      style={`--len:${dashLen}`}
    />

    <!-- precision square on the axis (the brand mark, reused as a data cursor) -->
    <rect
      x={markerX - 5}
      y={baseline - 5}
      width="10"
      height="10"
      class="fill-foreground stroke-background"
      stroke-width="3"
    />
  </svg>

  <figcaption class="mt-4 text-[0.8rem] leading-relaxed text-muted-foreground">
    {c.caption}
  </figcaption>
</figure>
