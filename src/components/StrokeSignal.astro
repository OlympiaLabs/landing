---
/**
 * The hero thesis: a kayak stroke as the sensor sees it. A synthetic but
 * believable IMU acceleration trace, drawn on load, sitting on the "waterline"
 * axis with the brand square marking one catch. The most characteristic
 * artifact in the sport's world — the page opens with the data, not a stock photo.
 */
interface Props {
  class?: string
}
const { class: className = '' } = Astro.props

// Geometry of the plot area (SVG user units).
const W = 560
const H = 240
const baseline = 132
const amp = 58
const periods = 3.5
const periodPx = W / periods
const step = 3

// Build the trace as a dense polyline so we can (a) keep it smooth and
// (b) measure its exact length for a clean stroke-dash draw animation.
let d = ''
let len = 0
let px = 0
let py = 0
for (let x = 0; x <= W; x += step) {
  const i = Math.floor(x / periodPx)
  const a = amp * (i % 2 === 0 ? 1 : 0.88) // slight L/R amplitude difference → "symmetry"
  const th = (2 * Math.PI * x) / periodPx
  const y = baseline - a * (Math.sin(th) + 0.32 * Math.sin(2 * th + 0.6))
  if (x === 0) {
    d = `M${x} ${y.toFixed(1)}`
  } else {
    d += ` L${x} ${y.toFixed(1)}`
    len += Math.hypot(x - px, y - py)
  }
  px = x
  py = y
}
const dashLen = Math.ceil(len) + 8
const catchX = 6 // square marker rides the axis at the first catch
---

<figure class={`relative ${className}`} aria-label="Stroke acceleration signal captured by the sensor">
  <svg viewBox={`0 0 ${W} ${H}`} class="w-full overflow-visible" role="img" aria-hidden="true">
    <!-- waterline axis (ink) with a red segment, echoing the logo -->
    <line x1="0" y1={baseline} x2={W} y2={baseline} class="stroke-border" stroke-width="1" />
    <line x1="0" y1={baseline} x2={periodPx * 0.62} y2={baseline} class="stroke-primary" stroke-width="1.5" />

    <!-- the trace -->
    <path
      d={d}
      fill="none"
      class="signal-path stroke-foreground"
      stroke-width="2.25"
      stroke-linecap="round"
      stroke-linejoin="round"
      style={`--len:${dashLen}`}
    />

    <!-- precision square on the catch (the brand mark, reused as a data cursor) -->
    <rect
      x={catchX - 5}
      y={baseline - 5}
      width="10"
      height="10"
      class="fill-foreground stroke-background"
      stroke-width="3"
    />
  </svg>

  <!-- the stroke, resolved into its four phases -->
  <div class="mt-3 flex justify-between border-t border-border pt-3 font-mono text-[0.6rem] uppercase tracking-label text-muted-foreground">
    <span>Catch</span>
    <span>Drive</span>
    <span>Exit</span>
    <span>Recovery</span>
  </div>

  <!-- mono readouts, top-right: the instrument voice -->
  <div class="pointer-events-none absolute right-0 top-0 flex flex-col items-end gap-1 font-mono text-[0.62rem] uppercase tracking-wide text-muted-foreground">
    <span><span class="text-foreground">6</span>-axis imu</span>
    <span>Δv <span class="text-foreground">4.2%</span></span>
    <span>sym <span class="text-primary">96%</span></span>
  </div>
</figure>
