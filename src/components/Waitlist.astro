---
import { WAITLIST_ENDPOINT } from '../config'

const inputClass =
  'h-12 w-full rounded-md border border-input bg-transparent px-4 text-base text-foreground placeholder:text-muted-foreground/70 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background'
---

<section id="waitlist" class="dark scroll-mt-20 bg-background text-foreground">
  <div class="wrap py-24 md:py-32">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-10">
      <div class="lg:col-span-6">
        <p class="label-caps">Early access</p>
        <h2 class="mt-5 text-[clamp(2rem,4.4vw,3.4rem)] font-semibold leading-[1.04] tracking-[-0.02em]">
          Be first on the water.
        </h2>
        <p class="mt-6 max-w-md text-lg leading-relaxed text-muted-foreground">
          We're opening to a small group of athletes and coaches. Join the waitlist and
          we'll reach out the moment your spot is ready.
        </p>
      </div>

      <div class="lg:col-span-6 lg:border-l lg:border-border lg:pl-10">
        <form
          id="waitlist-form"
          action={WAITLIST_ENDPOINT}
          method="POST"
          class="flex flex-col gap-5"
          novalidate
        >
          <div>
            <label for="wl-email" class="sr-only">Email address</label>
            <input
              id="wl-email"
              type="email"
              name="email"
              required
              autocomplete="email"
              placeholder="you@club.com"
              class={inputClass}
            />
          </div>

          <!-- honeypot: bots fill it, humans never see it -->
          <div class="hidden" aria-hidden="true">
            <label>Leave this field empty
              <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
            </label>
          </div>

          <label class="flex items-start gap-3 text-sm leading-relaxed text-muted-foreground">
            <input
              type="checkbox"
              name="consent"
              required
              class="mt-0.5 h-4 w-4 shrink-0 accent-primary"
            />
            <span>
              Email me about early access to OlympiaLabs. I can unsubscribe anytime.
            </span>
          </label>

          <p id="waitlist-error" role="alert" hidden class="text-sm font-medium text-primary"></p>

          <div class="flex flex-wrap items-center gap-4">
            <button
              type="submit"
              class="inline-flex h-12 items-center justify-center rounded-md bg-primary px-7 text-base font-medium text-primary-foreground transition-colors hover:bg-primary/90 disabled:cursor-not-allowed disabled:opacity-60"
            >
              Join the waitlist
            </button>
            <p class="font-mono text-[0.66rem] uppercase tracking-label text-muted-foreground">
              No spam · GDPR-compliant
            </p>
          </div>
        </form>

        <div
          id="waitlist-success"
          tabindex="-1"
          hidden
          class="flex items-start gap-4 rounded-md border border-border bg-muted/40 p-6"
        >
          <svg viewBox="0 0 24 24" class="mt-0.5 h-6 w-6 shrink-0 stroke-primary" fill="none" aria-hidden="true">
            <path d="M5 12.5l4.5 4.5L19 7.5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <div>
            <p class="font-semibold text-foreground">You're on the list.</p>
            <p class="mt-1 text-sm leading-relaxed text-muted-foreground">
              Thanks — we'll be in touch as places open up. Keep an eye on your inbox.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('waitlist-form') as HTMLFormElement | null
  if (form) {
    const errorEl = document.getElementById('waitlist-error') as HTMLElement
    const successEl = document.getElementById('waitlist-success') as HTMLElement
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement
    const endpoint = form.getAttribute('action') || ''
    const isDemo = endpoint === '' || endpoint.includes('your-form-id')

    const showError = (msg: string) => {
      errorEl.textContent = msg
      errorEl.hidden = false
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault()
      errorEl.hidden = true

      // honeypot tripped → silently drop
      const trap = form.querySelector('input[name="_gotcha"]') as HTMLInputElement | null
      if (trap && trap.value) return

      if (!form.reportValidity()) return

      if (isDemo) {
        showError('Demo mode — set PUBLIC_WAITLIST_ENDPOINT in .env to start collecting sign-ups.')
        return
      }

      const original = submitBtn.textContent
      submitBtn.disabled = true
      submitBtn.textContent = 'Joining…'

      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        })
        if (res.ok) {
          form.hidden = true
          successEl.hidden = false
          successEl.focus()
        } else {
          const data = await res.json().catch(() => null)
          const message = data?.errors?.[0]?.message ?? 'Something went wrong. Please try again.'
          showError(message)
          submitBtn.disabled = false
          submitBtn.textContent = original
        }
      } catch {
        showError('Network error — please check your connection and try again.')
        submitBtn.disabled = false
        submitBtn.textContent = original
      }
    })
  }
</script>
