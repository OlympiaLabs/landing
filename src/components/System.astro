---
const steps = [
  {
    n: '01',
    name: 'VectorSense',
    kind: 'The sensor',
    body: 'A small sensor on the boat captures motion at the source — acceleration, rotation and position, hundreds of times a second.',
  },
  {
    n: '02',
    name: 'KayakPro',
    kind: 'The capture app',
    body: 'Your phone records the session and the video, then pairs them with the sensor stream right there on the water.',
  },
  {
    n: '03',
    name: 'Cloud AI',
    kind: 'The analysis',
    body: 'Our models turn the raw signal into stroke phases, symmetry, stability and trends — and into coaching you can read.',
  },
]
---

<section id="system" class="scroll-mt-20 bg-muted/20">
  <div class="wrap py-24 md:py-32">
    <div class="max-w-2xl">
      <p class="label-caps">How it works</p>
      <h2 class="mt-5 text-[clamp(1.8rem,3.4vw,2.75rem)] font-semibold leading-[1.08] tracking-[-0.02em] text-foreground">
        Sensor to coaching, in one path.
      </h2>
    </div>

    <ol class="mt-14 grid grid-cols-1 gap-y-12 md:grid-cols-3 md:gap-x-10">
      {
        steps.map((s, i) => (
          <li class:list={['relative pt-7', i > 0 && 'md:border-l md:border-border md:pl-10']}>
            <span class="absolute left-0 top-0 h-px w-full bg-border" aria-hidden="true" />
            <span class="absolute left-0 top-0 h-px w-10 bg-primary" aria-hidden="true" />
            <span class="font-mono text-sm font-medium text-muted-foreground">{s.n}</span>
            <h3 class="mt-5 text-2xl font-semibold tracking-tight text-foreground">{s.name}</h3>
            <p class="mt-1 font-mono text-[0.7rem] uppercase tracking-label text-primary">{s.kind}</p>
            <p class="mt-4 leading-relaxed text-muted-foreground">{s.body}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
