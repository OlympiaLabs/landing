---
/**
 * Small Swiss data-viz motifs for the feature matrix — each encodes the metric
 * it labels, drawn as 1px line work with a single red accent. Not generic icons.
 */
interface Props {
  name: 'stroke' | 'symmetry' | 'stability' | 'fatigue' | 'sync' | 'coach'
  class?: string
}
const { name, class: className = 'h-9 w-9' } = Astro.props
const common = `${className} text-foreground`
---

{
  name === 'stroke' && (
    <svg class={common} viewBox="0 0 36 36" fill="none" aria-hidden="true">
      <line x1="2" y1="22" x2="34" y2="22" class="stroke-border" stroke-width="1" />
      <path
        d="M2 22 Q7 6 11 22 T20 22 T29 22"
        class="stroke-current"
        stroke-width="1.75"
        stroke-linecap="round"
      />
      <circle cx="7" cy="11.5" r="1.8" class="fill-primary" />
    </svg>
  )
}
{
  name === 'symmetry' && (
    <svg class={common} viewBox="0 0 36 36" fill="none" aria-hidden="true">
      <line x1="4" y1="18" x2="32" y2="18" class="stroke-border" stroke-width="1" />
      <line x1="9" y1="18" x2="9" y2="8" class="stroke-current" stroke-width="2" stroke-linecap="round" />
      <line x1="9" y1="18" x2="9" y2="26" class="stroke-current" stroke-width="2" stroke-linecap="round" />
      <line x1="18" y1="18" x2="18" y2="6" class="stroke-current" stroke-width="2" stroke-linecap="round" />
      <line x1="18" y1="18" x2="18" y2="24" class="stroke-current" stroke-width="2" stroke-linecap="round" />
      <line x1="27" y1="18" x2="27" y2="11" class="stroke-primary" stroke-width="2" stroke-linecap="round" />
      <line x1="27" y1="18" x2="27" y2="28" class="stroke-current" stroke-width="2" stroke-linecap="round" />
    </svg>
  )
}
{
  name === 'stability' && (
    <svg class={common} viewBox="0 0 36 36" fill="none" aria-hidden="true">
      <circle cx="18" cy="18" r="12" class="stroke-current" stroke-width="1.5" />
      <line x1="8" y1="21" x2="28" y2="15" class="stroke-primary" stroke-width="2" stroke-linecap="round" />
      <circle cx="18" cy="18" r="1.6" class="fill-current" />
    </svg>
  )
}
{
  name === 'fatigue' && (
    <svg class={common} viewBox="0 0 36 36" fill="none" aria-hidden="true">
      <line x1="3" y1="30" x2="33" y2="30" class="stroke-border" stroke-width="1" />
      <path d="M3 12 L11 14 L19 13 L25 19 L30 27" class="stroke-current" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M25 19 L30 27" class="stroke-primary" stroke-width="1.75" stroke-linecap="round" />
    </svg>
  )
}
{
  name === 'sync' && (
    <svg class={common} viewBox="0 0 36 36" fill="none" aria-hidden="true">
      <rect x="4" y="9" width="20" height="14" rx="1.5" class="stroke-current" stroke-width="1.5" />
      <rect x="11" y="15" width="20" height="14" rx="1.5" class="stroke-current" stroke-width="1.5" fill="hsl(var(--background))" />
      <line x1="21" y1="11" x2="21" y2="33" class="stroke-primary" stroke-width="1.75" />
    </svg>
  )
}
{
  name === 'coach' && (
    <svg class={common} viewBox="0 0 36 36" fill="none" aria-hidden="true">
      <circle cx="10" cy="13" r="4.5" class="stroke-current" stroke-width="1.5" />
      <circle cx="26" cy="23" r="4.5" class="stroke-primary" stroke-width="1.5" />
      <line x1="13.5" y1="16" x2="22.5" y2="20" class="stroke-current" stroke-width="1.5" stroke-linecap="round" />
    </svg>
  )
}
