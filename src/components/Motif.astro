---
/**
 * Small Swiss data-viz motifs for the "what it observes" matrix — each encodes
 * the thing it labels, drawn as 1px line work with a single red accent. Not
 * generic icons.
 *
 * The union below is the contract with `COPY.observes.items[].motif`. Keep them
 * in step: an unmatched name renders nothing at all.
 */
interface Props {
  name: 'boat' | 'body' | 'session' | 'history'
  class?: string
}
const { name, class: className = 'h-9 w-9' } = Astro.props
const common = `${className} text-foreground`
---

{/* boat — the hull on the waterline, heeled over: pitch and roll */}
{
  name === 'boat' && (
    <svg class={common} viewBox="0 0 36 36" fill="none" aria-hidden="true">
      <circle cx="18" cy="18" r="12" class="stroke-current" stroke-width="1.5" />
      <line x1="8" y1="21" x2="28" y2="15" class="stroke-primary" stroke-width="2" stroke-linecap="round" />
      <circle cx="18" cy="18" r="1.6" class="fill-current" />
    </svg>
  )
}

{/* body — a paddler abstracted to segments, one joint picked out */}
{
  name === 'body' && (
    <svg class={common} viewBox="0 0 36 36" fill="none" aria-hidden="true">
      <circle cx="18" cy="7" r="3" class="stroke-current" stroke-width="1.5" />
      <line x1="18" y1="10.5" x2="18" y2="22" class="stroke-current" stroke-width="1.75" stroke-linecap="round" />
      <line x1="18" y1="13.5" x2="9" y2="18" class="stroke-current" stroke-width="1.5" stroke-linecap="round" />
      <line x1="18" y1="13.5" x2="27" y2="9" class="stroke-primary" stroke-width="1.5" stroke-linecap="round" />
      <line x1="18" y1="22" x2="12.5" y2="30" class="stroke-current" stroke-width="1.5" stroke-linecap="round" />
      <line x1="18" y1="22" x2="23.5" y2="30" class="stroke-current" stroke-width="1.5" stroke-linecap="round" />
      <circle cx="18" cy="13.5" r="1.7" class="fill-primary" />
    </svg>
  )
}

{/* session — motion, track and video stacked on one shared timeline cursor */}
{
  name === 'session' && (
    <svg class={common} viewBox="0 0 36 36" fill="none" aria-hidden="true">
      <rect x="4" y="9" width="20" height="14" rx="1.5" class="stroke-current" stroke-width="1.5" />
      <rect
        x="11"
        y="15"
        width="20"
        height="14"
        rx="1.5"
        class="stroke-current"
        stroke-width="1.5"
        fill="hsl(var(--background))"
      />
      <line x1="21" y1="11" x2="21" y2="33" class="stroke-primary" stroke-width="1.75" />
    </svg>
  )
}

{/* history — sessions as deviations from the athlete's own baseline */}
{
  name === 'history' && (
    <svg class={common} viewBox="0 0 36 36" fill="none" aria-hidden="true">
      <line x1="3" y1="18" x2="33" y2="18" class="stroke-border" stroke-width="1" />
      <line x1="7" y1="18" x2="7" y2="12" class="stroke-current" stroke-width="2" stroke-linecap="round" />
      <line x1="13" y1="18" x2="13" y2="21" class="stroke-current" stroke-width="2" stroke-linecap="round" />
      <line x1="19" y1="18" x2="19" y2="10" class="stroke-current" stroke-width="2" stroke-linecap="round" />
      <line x1="25" y1="18" x2="25" y2="15" class="stroke-current" stroke-width="2" stroke-linecap="round" />
      <line x1="31" y1="18" x2="31" y2="24" class="stroke-primary" stroke-width="2" stroke-linecap="round" />
    </svg>
  )
}
