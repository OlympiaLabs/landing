---
/**
 * The three parts, named plainly. The internal product names (VectorSense,
 * KayakPro) are deliberately not used here — three brands to learn before you
 * understand the value is work the visitor shouldn't have to do.
 */
import { getCopy } from '../copy'
import { getLocaleFromPath } from '../i18n'

const locale = getLocaleFromPath(Astro.url.pathname)
const c = getCopy(locale).pieces
---

<section class="scroll-mt-20">
  <div class="wrap py-24 md:py-32">
    <div class="max-w-2xl">
      <p class="label-caps">{c.eyebrow}</p>
      <h2
        class="mt-5 text-[clamp(1.8rem,3.4vw,2.75rem)] font-semibold leading-[1.08] tracking-[-0.02em] text-foreground"
      >
        {c.title}
      </h2>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-y-10 md:grid-cols-3 md:gap-x-10">
      {
        c.items.map((p) => (
          <div class="reveal relative pt-7">
            <span class="absolute left-0 top-0 h-px w-full bg-border" aria-hidden="true" />
            <span class="absolute left-0 top-0 h-px w-10 bg-primary" aria-hidden="true" />
            <p class="font-mono text-[0.66rem] uppercase tracking-label text-primary">{p.where}</p>
            <h3 class="mt-3 text-xl font-semibold tracking-tight text-foreground">{p.name}</h3>
            <p class="mt-3 leading-relaxed text-muted-foreground">{p.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
