---
/**
 * The spine of the page: where every number comes from.
 *
 * Four columns — measured / calculated / AI-estimated / not claimed. The last
 * one is the unusual one and the reason the other three are believable; it gets
 * the red treatment because it's the column a coach will actually check.
 *
 * Anything added here must match the system as built. See the claims block at
 * the top of `copy.ts` before touching the lists.
 */
import { getCopy } from '../copy'
import { getLocaleFromPath } from '../i18n'

const locale = getLocaleFromPath(Astro.url.pathname)
const c = getCopy(locale).trust
---

<section id="trust" class="scroll-mt-20 bg-muted/20">
  <div class="wrap py-24 md:py-32">
    <div class="max-w-2xl">
      <p class="label-caps">{c.eyebrow}</p>
      <h2
        class="mt-5 text-[clamp(1.8rem,3.4vw,2.75rem)] font-semibold leading-[1.08] tracking-[-0.02em] text-foreground"
      >
        {c.title}
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-muted-foreground">{c.body}</p>
    </div>

    <div class="mt-14 grid grid-cols-1 border-l border-t border-border sm:grid-cols-2 lg:grid-cols-4">
      {
        c.columns.map((col, i) => {
          // The last column is the disclaimer column — accent it.
          const isDisclaimer = i === c.columns.length - 1
          return (
            <div class="reveal border-b border-r border-border p-7 md:p-8">
              <p
                class:list={[
                  'font-mono text-[0.7rem] font-medium uppercase tracking-label',
                  isDisclaimer ? 'text-primary' : 'text-foreground',
                ]}
              >
                {col.kind}
              </p>
              <p class="mt-1.5 text-[0.8rem] leading-relaxed text-muted-foreground">{col.note}</p>

              <ul class="mt-6 space-y-4">
                {col.items.map((item) => (
                  <li class="flex gap-3 text-[0.9rem] leading-relaxed text-muted-foreground">
                    <span
                      aria-hidden="true"
                      class:list={[
                        'mt-2.5 h-px w-3 shrink-0',
                        isDisclaimer ? 'bg-primary' : 'bg-border',
                      ]}
                    />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          )
        })
      }
    </div>

    <p class="mt-12 border-t border-border pt-8 text-lg font-medium leading-relaxed text-foreground">
      {c.closing}
    </p>
  </div>
</section>
