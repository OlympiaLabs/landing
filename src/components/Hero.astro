---
import StrokeSignal from './StrokeSignal.astro'
import { getCopy } from '../copy'
import { getLocaleFromPath } from '../i18n'

const locale = getLocaleFromPath(Astro.url.pathname)
const c = getCopy(locale).hero
---

<section id="top" class="relative overflow-hidden">
  <div
    class="pointer-events-none absolute inset-x-0 top-[-12rem] h-[34rem] bg-[radial-gradient(circle_at_0%_0%,rgba(227,30,36,0.16),transparent_34%),radial-gradient(circle_at_82%_18%,rgba(17,17,17,0.08),transparent_32%)]"
  ></div>
  <div class="pointer-events-none absolute right-[-7rem] top-14 h-64 w-64 rounded-full bg-primary/10 blur-3xl"></div>

  <div class="wrap relative grid grid-cols-1 items-center gap-14 py-20 md:py-28 lg:grid-cols-12 lg:gap-10 lg:py-32">
    <div class="lg:col-span-7">
      <div
        class="enter inline-flex items-center gap-2 rounded-full border border-primary/15 bg-primary/[0.06] px-3 py-1.5 font-mono text-[0.66rem] font-medium uppercase tracking-label text-primary"
        style="animation-delay:0ms"
      >
        <span aria-hidden="true" class="h-2 w-2 rounded-full bg-primary"></span>
        {c.badge}
      </div>

      <p class="label-caps enter mt-6" style="animation-delay:80ms">{c.eyebrow}</p>

      <h1 class="mt-6 text-[clamp(2.5rem,6.2vw,5rem)] font-bold leading-[0.95] tracking-[-0.02em] text-foreground">
        <span class="enter block" style="animation-delay:160ms">{c.titleTop}</span>
        <span class="enter block font-light text-muted-foreground" style="animation-delay:240ms">{c.titleBottom}</span>
      </h1>

      <div class="enter mt-8 h-px w-28 bg-primary" style="animation-delay:320ms"></div>

      <p class="enter mt-8 max-w-2xl text-lg leading-relaxed text-muted-foreground" style="animation-delay:400ms">
        {c.body}
      </p>

      <div class="enter mt-10 flex flex-wrap items-center gap-x-7 gap-y-4" style="animation-delay:480ms">
        <a
          href="#waitlist"
          class="inline-flex h-12 items-center justify-center rounded-md bg-primary px-7 text-base font-medium text-primary-foreground transition-colors hover:bg-primary/90"
        >
          {c.ctaPrimary}
        </a>
        <a href="#coach" class="group inline-flex items-center gap-2 text-base font-medium text-foreground">
          {c.ctaSecondary}
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
        </a>
      </div>

      <ul class="mt-10 grid gap-3 text-sm text-foreground sm:grid-cols-3">
        {
          c.highlights.map((item, i) => (
            <li
              class="enter flex items-start gap-3 rounded-2xl border border-border bg-background/85 px-4 py-4 shadow-[0_18px_40px_-32px_rgba(17,17,17,0.5)] backdrop-blur-sm"
              style={`animation-delay:${560 + i * 80}ms`}
            >
              <span aria-hidden="true" class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-primary"></span>
              <span class="leading-relaxed text-muted-foreground">{item}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="enter relative lg:col-span-5" style="animation-delay:720ms">
      <div class="absolute inset-0 translate-x-4 translate-y-5 rounded-[1.75rem] bg-muted/80"></div>

      <div
        class="relative overflow-hidden rounded-[1.75rem] border border-border bg-card/95 p-6 shadow-[0_30px_80px_-48px_rgba(17,17,17,0.45)] backdrop-blur-sm md:p-7"
      >
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_100%_0%,rgba(227,30,36,0.1),transparent_34%),linear-gradient(180deg,rgba(17,17,17,0.02),transparent_44%)]"></div>
        <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-primary via-primary/30 to-transparent"></div>

        <div class="relative">
          <p class="font-mono text-[0.66rem] font-medium uppercase tracking-label text-primary">{c.panel.eyebrow}</p>
          <h2 class="mt-4 max-w-sm text-[1.65rem] font-semibold leading-tight tracking-tight text-foreground">
            {c.panel.title}
          </h2>

          <div class="mt-6 grid gap-3">
            {
              c.panel.points.map((point) => (
                <div class="rounded-[1.15rem] border border-border bg-background/88 p-4 shadow-[0_18px_40px_-34px_rgba(17,17,17,0.45)] backdrop-blur-sm">
                  <p class="text-base font-semibold tracking-tight text-foreground">{point.title}</p>
                  <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{point.body}</p>
                </div>
              ))
            }
          </div>

          <div class="mt-6 rounded-[1.4rem] border border-border bg-foreground/[0.02] p-4">
            <div class="flex flex-wrap items-center justify-between gap-3 border-b border-border pb-4">
              <p class="font-mono text-[0.62rem] font-medium uppercase tracking-label text-primary">
                {c.signal.eyebrow}
              </p>

              {
                c.signal.readouts.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {c.signal.readouts.map((readout) => (
                      <span class="rounded-full border border-border bg-background/90 px-3 py-1 font-mono text-[0.62rem] uppercase tracking-label">
                        <span class="text-foreground">{readout.n}</span>
                        <span class="text-muted-foreground">{readout.t}</span>
                      </span>
                    ))}
                  </div>
                )
              }
            </div>

            <StrokeSignal class="mt-4" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
