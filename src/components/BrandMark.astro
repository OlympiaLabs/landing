---
/**
 * The landing site reuses the webapp's current mark: a neutral compass icon
 * with the single brand accent confined to the mark itself.
 */
interface Props {
  class?: string
  title?: string
}
const { class: className = 'size-5', title = 'OlympiaLabs' } = Astro.props
---

<svg
  class={className}
  viewBox="0 0 24 24"
  role="img"
  aria-label={title}
  xmlns="http://www.w3.org/2000/svg"
  fill="none"
>
  <circle cx="12" cy="12" r="10" class="stroke-current" stroke-width="1.75" />
  <polygon
    points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"
    class="stroke-current"
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="1.75"
  />
</svg>
