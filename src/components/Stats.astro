---
import { COPY } from '../copy'

const c = COPY.stats
---

<section aria-label={c.label} class="bg-muted/20">
  <div class="wrap py-12 md:py-16">
    <div class="grid grid-cols-2 border-l border-t border-border md:grid-cols-4">
      {
        c.items.map((s) => (
          <div class="reveal flex flex-col gap-2 border-b border-r border-border px-5 py-7 md:px-7 md:py-8">
            <span class="font-mono text-[1.7rem] font-medium leading-none tracking-tight text-foreground md:text-4xl">
              {s.v}
            </span>
            <span class="label-caps">{s.l}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
