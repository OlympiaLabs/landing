---
const stats = [
  { v: '6-axis', l: 'Inertial sensing' },
  { v: '4', l: 'Stroke phases, timed' },
  { v: 'L / R', l: 'Bilateral symmetry' },
  { v: '3-axis', l: 'Boat attitude' },
]
---

<section aria-label="At a glance" class="bg-muted/20">
  <div class="wrap py-12 md:py-16">
    <div class="grid grid-cols-2 border-l border-t border-border md:grid-cols-4">
      {
        stats.map((s) => (
          <div class="flex flex-col gap-2 border-b border-r border-border px-5 py-7 md:px-7 md:py-8">
            <span class="font-mono text-[1.7rem] font-medium leading-none tracking-tight text-foreground md:text-4xl">
              {s.v}
            </span>
            <span class="label-caps">{s.l}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
