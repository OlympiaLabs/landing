---
import { getCopy } from '../copy'
import { getLocaleFromPath } from '../i18n'

const locale = getLocaleFromPath(Astro.url.pathname)
const c = getCopy(locale).stats
---

<section aria-label={c.label} class="bg-muted/20">
  <div class="wrap py-16 md:py-20">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,20rem)_1fr] lg:items-start lg:gap-12">
      <div class="max-w-sm">
        <p class="label-caps">{c.eyebrow}</p>
        <h2
          class="mt-5 text-[clamp(1.7rem,3.2vw,2.5rem)] font-semibold leading-[1.08] tracking-[-0.02em] text-foreground"
        >
          {c.title}
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-muted-foreground">{c.body}</p>
      </div>

      <div class="grid grid-cols-1 border-l border-t border-border sm:grid-cols-2">
        {
          c.items.map((s) => (
            <article class="reveal border-b border-r border-border bg-background/80 px-6 py-7 md:p-8">
              <p class="font-mono text-[0.66rem] font-medium uppercase tracking-label text-primary">{s.tag}</p>
              <h3 class="mt-3 text-xl font-semibold tracking-tight text-foreground">{s.title}</h3>
              <p class="mt-3 text-[0.95rem] leading-relaxed text-muted-foreground">{s.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
