# --- OlympiaLabs landing site configuration -------------------------------
# Copy to `.env` and fill in. Only PUBLIC_* vars are exposed to the browser.

# Waitlist form endpoint. Default is Formspree: create a form at
# https://formspree.io and paste its endpoint below. Any service that accepts a
# POST of form fields works the same way (Buttondown, Tally, Mailchimp, …) —
# Buttondown is the better pick if you want to email the list at launch.
PUBLIC_WAITLIST_ENDPOINT="https://formspree.io/f/your-form-id"

# Origin of the product webapp. "Sign in" / "Open app" links resolve to
# `${PUBLIC_APP_URL}/login`. In local dev this is usually https://localhost.
PUBLIC_APP_URL="https://app.olympialabs.eu"
