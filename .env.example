# --- OlympiaLabs landing site configuration -------------------------------
# Copy to `.env` and fill in. Only PUBLIC_* vars are exposed to the browser.
#
# The waitlist uses Netlify Forms (no endpoint/key needed) — see README.

# Origin of the product webapp. "Sign in" / "Open app" links resolve to
# `${PUBLIC_APP_URL}/login`. In local dev this is usually https://localhost.
PUBLIC_APP_URL="https://app.olympialabs.eu"

# --- Analytics (optional) -------------------------------------------------
# Leave unset and no script tag ships at all — that is the default, and it is
# also the current state of production: the page has never been measured, so
# its conversion rate is unknown.
#
# Set the SRC plus the one attribute your provider reads. Both options below
# are cookieless, which is what keeps a consent banner off the page; pick one.
#
# Umami, self-hosted next to the webapp (data stays on your infrastructure —
# no third-party processor, so nothing to add to the privacy notice's
# recipients list):
#   PUBLIC_ANALYTICS_SRC="https://umami.example.eu/script.js"
#   PUBLIC_ANALYTICS_WEBSITE_ID="00000000-0000-0000-0000-000000000000"
#
# Plausible Cloud (EU-hosted; it is a processor, so name it in the privacy
# notice under "Who else sees it" before enabling):
#   PUBLIC_ANALYTICS_SRC="https://plausible.io/js/script.js"
#   PUBLIC_ANALYTICS_DOMAIN="olympialabs.eu"
